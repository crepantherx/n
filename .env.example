# Optional but recommended for stable signed sessions across restarts/machines.
# Generate a long random value and keep it private.
NAUKRI_SECRET_KEY=

# Web server binding. Use 127.0.0.1 for local-only access.
NAUKRI_WEB_HOST=127.0.0.1
NAUKRI_WEB_PORT=8787

# Optional Google OAuth / Drive sync.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional upload limit in bytes. Default is 15728640 (15 MB).
NAUKRI_MAX_UPLOAD_BYTES=15728640

# Optional legacy environment fallbacks. Dashboard per-user settings normally replace these.
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
RESUME_PATH=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_PHONE=
REED_EMAIL=
REED_PASSWORD=
CTC_INR=
JOB_TITLES=ML Engineer, AI Engineer, Software Engineer

# Vercel/serverless dashboard mode. Leave unset for local desktop installs.
NAUKRI_CLOUD_MODE=0
NAUKRI_ADMIN_EMAIL=
NAUKRI_ADMIN_PASSWORD=
# Or provide a precomputed PBKDF2 hash instead of the plain admin password.
NAUKRI_ADMIN_PASSWORD_HASH=
GOOGLE_ALLOWED_EMAILS=
CRON_SECRET=
NAUKRI_ENABLE_VERCEL_RUNS=0
NAUKRI_VERCEL_TASK=naukri
NAUKRI_VERCEL_TARGET=5

# GitHub Actions / cloud-worker resume support.
# Store the base64 string as an encrypted secret, not in source control.
RESUME_BASE64=
RESUME_FILENAME=resume.pdf
RUN_TASKS=naukri
RUN_TARGET=30
